*/**/.undodir
lazy-lock.json
home/.oh-my-zsh/custom/secrets.zsh
home/.config/opencode/amp_stuff/
.envrc
backups/
packages/failed_packages_*.txt
tmp/
.DS_STORE
home/.agents/skills/ui/


# Python
__pycache__/
*.pyc

# jj
.jj

# skills CLI config/state — written when the `skills` CLI runs on the canonical
# checkout (~/.config is stowed). `dot skills` redirects it away, but guard the
# stow tree against raw `skills` invocations too.
home/.config/skills/

# opencode
home/.config/opencode/node_modules/
home/.config/opencode/plugins/git-ai.ts
.opencode/plans/

# herdr runtime/state
home/.config/herdr/*.log
home/.config/herdr/session-history.json
home/.config/herdr/session.json
home/.config/herdr/release-notes.json

# jj per-repo configs
home/.config/jj/repos/

# pi agent runtime/state (keep settings + customization resources tracked)
home/.pi/agent/*
home/.pi/todos/*
home/.pi/.pi/todos/*
.pi/todos/*

# pi MCP adapter runtime/secrets
home/.pi/agent/mcp-oauth/
home/.pi/agent/mcp-cache.json
home/.pi/agent/mcp-npx-cache.json
home/.pi/agent/mcp-auth.json
home/.local/share/pi/mcp-auth.json

# pi extensions node_modules
home/.pi/agent/extensions/**/node_modules/

# pi bun lockfile — bun install rewrites it via rename, breaking the stow
# symlink; let bun own it locally instead of stowing it
home/.pi/bun.lock


