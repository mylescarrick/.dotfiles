{
  "defaultFamily": "azure-gpt",
  "autoRoute": true,
  "returnRole": "delivery",
  "families": {
    "azure-gpt": {
      "description": "Cache-stable Azure OpenAI GPT-5.6 defaults: Terra medium for every automatic role. Sol high and Luna low are explicit persistent targets only.",
      "roles": {
        "research": {
          "provider": "azure-openai-responses",
          "model": "gpt-5.6-terra",
          "thinkingLevel": "medium"
        },
        "architecture": {
          "provider": "azure-openai-responses",
          "model": "gpt-5.6-terra",
          "thinkingLevel": "medium"
        },
        "planning": {
          "provider": "azure-openai-responses",
          "model": "gpt-5.6-terra",
          "thinkingLevel": "medium"
        },
        "delivery": {
          "provider": "azure-openai-responses",
          "model": "gpt-5.6-terra",
          "thinkingLevel": "medium"
        },
        "verification": {
          "provider": "azure-openai-responses",
          "model": "gpt-5.6-terra",
          "thinkingLevel": "medium"
        }
      },
      "manualTargets": {
        "sol": {
          "description": "Exceptional long-horizon reasoning; stays locked until /mf auto.",
          "provider": "azure-openai-responses",
          "model": "gpt-5.6-sol",
          "thinkingLevel": "high"
        },
        "luna": {
          "description": "Explicit low-cost bounded work; stays locked until /mf auto.",
          "provider": "azure-openai-responses",
          "model": "gpt-5.6-luna",
          "thinkingLevel": "low"
        }
      }
    },
    "open-weight-cloudflare": {
      "description": "Open-weight-ish models via Cloudflare Workers AI / AI Gateway: GLM for research and architecture, Kimi Code for delivery.",
      "roles": {
        "research": {
          "provider": "cloudflare-workers-ai",
          "model": "@cf/zai-org/glm-5.2",
          "thinkingLevel": "high"
        },
        "architecture": {
          "provider": "cloudflare-workers-ai",
          "model": "@cf/zai-org/glm-5.2",
          "thinkingLevel": "high"
        },
        "planning": {
          "provider": "cloudflare-workers-ai",
          "model": "@cf/zai-org/glm-5.2",
          "thinkingLevel": "high"
        },
        "delivery": {
          "provider": "cloudflare-workers-ai",
          "model": "@cf/moonshotai/kimi-k2.7-code",
          "thinkingLevel": "low"
        },
        "verification": {
          "provider": "cloudflare-workers-ai",
          "model": "@cf/moonshotai/kimi-k2.7-code",
          "thinkingLevel": "low"
        }
      },
      "disabled": true
    },
    "copilot-main": {
      "description": "Main Copilot defaults: GPT-5.5 for research/planning/architecture, Kimi K2.7 Code for delivery/verification.",
      "roles": {
        "research": {
          "provider": "github-copilot",
          "model": "gpt-5.5",
          "thinkingLevel": "high"
        },
        "architecture": {
          "provider": "github-copilot",
          "model": "gpt-5.5",
          "thinkingLevel": "high"
        },
        "planning": {
          "provider": "github-copilot",
          "model": "gpt-5.5",
          "thinkingLevel": "high"
        },
        "delivery": {
          "provider": "github-copilot",
          "model": "kimi-k2.7-code",
          "thinkingLevel": "low"
        },
        "verification": {
          "provider": "github-copilot",
          "model": "kimi-k2.7-code",
          "thinkingLevel": "low"
        }
      }
    },
    "copilot-budget": {
      "description": "Budget Copilot defaults: GPT-5.5 for planning/architecture, MAI-Code for delivery.",
      "roles": {
        "research": {
          "provider": "github-copilot",
