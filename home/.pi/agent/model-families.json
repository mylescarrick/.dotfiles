          "thinkingLevel": "high"
        },
        "planning": {
          "provider": "github-copilot",
          "model": "gpt-5.5",
          "thinkingLevel": "high"
        },
        "delivery": {
          "provider": "github-copilot",
          "model": "mai-code-1-flash-picker",
          "thinkingLevel": "low"
        },
        "verification": {
          "provider": "github-copilot",
          "model": "mai-code-1-flash-picker",
          "thinkingLevel": "low"
        }
      }
    },
    "claude-fable": {
      "description": "Claude Bridge Fable for planning/architecture, Opus 4.8 for building.",
      "roles": {
        "research": {
          "provider": "claude-bridge",
          "model": "claude-fable-5",
          "thinkingLevel": "high"
        },
        "architecture": {
