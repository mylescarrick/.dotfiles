          "thinkingLevel": "medium"
        },
        "verification": {
          "provider": "claude-bridge",
          "model": "claude-opus-4-8",
          "thinkingLevel": "low"
        }
      }
    },
    "claude-main": {
      "description": "Claude Bridge mainline: Opus 4.8 for planning/architecture, Sonnet 5 for building.",
      "roles": {
        "research": {
          "provider": "claude-bridge",
          "model": "claude-opus-4-8",
          "thinkingLevel": "high"
        },
        "architecture": {
          "provider": "claude-bridge",
