{
  "name": ".pi",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "agent/extensions/*"
  ],
  "scripts": {
    "check": "npm run check --workspace=pi-extension-opencode-cloudflare && npm run check --workspace=pi-model-families-extension && npm run check --workspace=pi-save-md-extension && npm run check --workspace=pi-web-tools-extension",
    "test:save-md": "npm run test --workspace=pi-save-md-extension",
    "test:web-tools": "npm run test --workspace=pi-web-tools-extension",
    "test:codex-fast-mode": "node --import tsx --test tests/codex-fast-mode.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.76.0",
    "@earendil-works/pi-coding-agent": "^0.76.0",
    "@earendil-works/pi-tui": "^0.76.0",
    "typebox": "^1.1.38"
  }
}
