{
  "name": "pi-model-families",
  "version": "0.1.0",
  "description": "Role-based model family routing for the Pi coding agent",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "model-routing"
  ],
  "scripts": {
    "check": "npm run check --workspace=pi-model-families-extension"
  },
  "workspaces": [
    "extensions/*"
  ],
  "files": [
    "README.md",
    "examples",
    "extensions/model-families"
  ],
  "pi": {
    "extensions": [
      "./extensions/model-families"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  }
}
